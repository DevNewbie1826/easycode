{
  "name": "easycode-plugin",
  "version": "0.1.0",
  "description": "OpenCode plugin base scaffold",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/agents",
    "src/hooks/skill-bootstrap",
    "src/skills"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types && bun run install:local",
    "build:js": "bun build src/index.ts --outdir dist --target bun --external @opencode-ai/plugin",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "bun build src/index.ts --outdir dist --target bun --watch --external @opencode-ai/plugin",
    "typecheck": "tsc --noEmit",
    "install:local": "mkdir -p .opencode/plugins && cp dist/index.js .opencode/plugins/easycode.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.10",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.10"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "coding"
  ],
  "license": "MIT"
}
